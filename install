# ─── Create iris-onboard launcher script ─────────────────────────────────────
# Write prompt to a file (keeps tokens out of ps output), then launch from file.

PROMPT_FILE="$HOME/.iris/.onboarding-prompt"
echo "$ONBOARDING_PROMPT" > "$PROMPT_FILE"
chmod 600 "$PROMPT_FILE"

cat > "$INSTALL_DIR/iris-onboard" << 'ONBOARD'
#!/usr/bin/env bash
cd "$HOME"
PROMPT_FILE="$HOME/.iris/.onboarding-prompt"
if [ -f "$PROMPT_FILE" ]; then
    exec "$HOME/.iris/bin/iris" -m opencode/big-pickle --prompt "$(cat "$PROMPT_FILE")"
else
    exec "$HOME/.iris/bin/iris" -m opencode/big-pickle
fi
ONBOARD
chmod 755 "$INSTALL_DIR/iris-onboard"

# ─── Next Steps ───────────────────────────────────────────────────────────────
# Direct run: exec iris. Piped from curl: copy to clipboard + instructions.

if [ -t 0 ]; then
    echo -e "${MUTED}Starting IRIS CLI...${NC}"
    echo -e ""
    cd "$HOME"
    exec "$INSTALL_DIR/iris" -m opencode/big-pickle --prompt "$(cat "$PROMPT_FILE")"
else
    echo -e ""
    if [ "$AUTH_SUCCESS" = "true" ] || ([ -f "$HOME/.iris/sdk/.env" ] && grep -q "IRIS_API_KEY=." "$HOME/.iris/sdk/.env" 2>/dev/null); then
        echo -e "  ${GREEN}Ready to go!${NC} To get started, run:"
        echo -e ""
        echo -e "    ${CYAN}source ~/.iris/env && iris-onboard${NC}"
        echo -e ""
        if command -v pbcopy &>/dev/null; then
            printf "%s" "source ~/.iris/env && iris-onboard" | pbcopy
            echo -e "  ${MUTED}(command copied to clipboard)${NC}"
            echo -e ""
        fi
    else
        echo -e "  ${GREEN}To get started, run:${NC}"
        echo -e ""
        echo -e "    ${CYAN}source ~/.iris/env && iris-login${NC}"
        echo -e ""
        if command -v pbcopy &>/dev/null; then
            printf "%s" "source ~/.iris/env && iris-login" | pbcopy
            echo -e "  ${MUTED}(command copied to clipboard)${NC}"
            echo -e ""
        fi
    fi
fi
