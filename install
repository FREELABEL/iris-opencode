# ─── Create iris-onboard launcher script ─────────────────────────────────────
# Write prompt to a file (keeps tokens out of ps output), then launch from file.

PROMPT_FILE="$HOME/.iris/.onboarding-prompt"
echo "$ONBOARDING_PROMPT" > "$PROMPT_FILE"
chmod 600 "$PROMPT_FILE"

cat > "$INSTALL_DIR/iris-onboard" << 'ONBOARD'
#!/usr/bin/env bash
cd "$HOME"
PROMPT_FILE="$HOME/.iris/.onboarding-prompt"
if [ -f "$PROMPT_FILE" ]; then
    exec "$HOME/.iris/bin/iris" -m opencode/gpt-5-nano --prompt "$(cat "$PROMPT_FILE")"
else
    exec "$HOME/.iris/bin/iris" -m opencode/gpt-5-nano
fi
ONBOARD
chmod 755 "$INSTALL_DIR/iris-onboard"

# Symlink all CLI commands into a directory that's already in PATH.
# Try /usr/local/bin first (always in PATH on macOS/Linux), then fallbacks.
symlinked=false
for dir in "/usr/local/bin" "$HOME/.local/bin" "$HOME/bin"; do
    if [ -d "$dir" ] && [ -w "$dir" ]; then
        ln -sf "$INSTALL_DIR/iris" "$dir/iris" 2>/dev/null || true
        ln -sf "$INSTALL_DIR/iris-onboard" "$dir/iris-onboard" 2>/dev/null || true
        ln -sf "$INSTALL_DIR/iris-login" "$dir/iris-login" 2>/dev/null || true
        symlinked=true
        break
    fi
done

# Fallback: create ~/.local/bin if nothing was writable
if [ "$symlinked" = "false" ]; then
    mkdir -p "$HOME/.local/bin" 2>/dev/null || true
    if [ -d "$HOME/.local/bin" ]; then
        ln -sf "$INSTALL_DIR/iris" "$HOME/.local/bin/iris" 2>/dev/null || true
        ln -sf "$INSTALL_DIR/iris-onboard" "$HOME/.local/bin/iris-onboard" 2>/dev/null || true
        ln -sf "$INSTALL_DIR/iris-login" "$HOME/.local/bin/iris-login" 2>/dev/null || true
    fi
fi

# ─── Next Steps ───────────────────────────────────────────────────────────────
# Direct run: exec iris. Piped from curl: copy to clipboard + instructions.

if [ -t 0 ]; then
    echo -e "${MUTED}Starting IRIS Code...${NC}"
    echo -e ""
    cd "$HOME"
    exec "$INSTALL_DIR/iris" -m opencode/gpt-5-nano --prompt "$(cat "$PROMPT_FILE")"
else
    echo -e ""
    # Determine the command to show — use short name if it resolves, full path otherwise
    if command -v iris-onboard >/dev/null 2>&1; then
        onboard_cmd="iris-onboard"
        login_cmd="iris-login"
    else
        onboard_cmd="$INSTALL_DIR/iris-onboard"
        login_cmd="$INSTALL_DIR/iris-login"
    fi

    if [ "$AUTH_SUCCESS" = "true" ] || ([ -f "$HOME/.iris/sdk/.env" ] && grep -q "IRIS_API_KEY=." "$HOME/.iris/sdk/.env" 2>/dev/null); then
        # Already authenticated — skip login prompt
        echo -e "  ${GREEN}Ready to go!${NC} Open a new terminal and run:"
        echo -e ""
        echo -e "    ${CYAN}${onboard_cmd}${NC}"
        echo -e ""
        if command -v pbcopy &>/dev/null; then
            printf "%s" "$onboard_cmd" | pbcopy
            echo -e "  ${MUTED}(copied to clipboard — just ⌘V + Enter)${NC}"
            echo -e ""
        fi
    else
        # Not authenticated — show login prompt
        if command -v pbcopy &>/dev/null; then
            printf "%s" "$login_cmd" | pbcopy
        fi
        echo -e "  ${GREEN}Next step${NC} — open a new terminal and authenticate:"
        echo -e ""
        echo -e "    ${CYAN}${login_cmd}${NC}"
        echo -e ""
        echo -e "  ${MUTED}Then start the AI assistant:${NC}"
        echo -e "    ${CYAN}${onboard_cmd}${NC}"
        echo -e ""
        if command -v pbcopy &>/dev/null; then
            echo -e "  ${MUTED}(${NC}${login_cmd}${MUTED} copied to clipboard — just ⌘V + Enter)${NC}"
            echo -e ""
        fi
    fi
fi
